---
import { getCollection } from "astro:content";
import { withBase } from "../lib/paths.js";
import { hasText, trimText } from "../lib/content-display.js";
import "../styles/site.css";

const siteName = "Anthony Fish Care";
const siteEntry = (await getCollection("site"))[0] ?? null;
const siteContent = siteEntry?.data ?? {};

const fallbackFooterText =
  "A hobby fish-care reference for sharing care sheets, fishkeeping notes, and QR-linked care information. Not an online store.";
const fallbackContactText =
  "Contact details will be added after Anthony chooses a public contact method.";

const {
  title = siteName,
  description = "A calm fish-care reference for sharing care sheets and notes.",
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const brandName = trimText(siteContent.siteName) || siteName;
const footerText = trimText(siteContent.tagline) || fallbackFooterText;
const showContact = siteContent.showContact !== false;
const contactHeading = trimText(siteContent.contactHeading) || "Contact";
const contactText = trimText(siteContent.contactText) || fallbackContactText;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href={withBase("favicon.svg")} />
  </head>
  <body>
    <header class="site-header">
      <a class="site-brand" href={withBase()}>{brandName}</a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href={withBase("fish/")}>Fish Care Sheets</a>
        <a href={withBase("notes/")}>Fishkeeping Notes</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <div>
        <p class="footer-title">{brandName}</p>
        <p>{footerText}</p>
      </div>
      {showContact && hasText(contactText) ? (
        <div>
          <p class="footer-title">{contactHeading}</p>
          <p>{contactText}</p>
        </div>
      ) : null}
    </footer>
  </body>
</html>
