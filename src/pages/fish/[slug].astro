---
import { getCollection } from "astro:content";
import FishPage from "../../components/FishPage.astro";
import { normalizeContentSlug } from "../../lib/paths.js";

export async function getStaticPaths() {
  const fishEntries = await getCollection("fish");

  return fishEntries
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({
      params: { slug: normalizeContentSlug(entry.id) },
      props: { fish: entry.data },
    }));
}

const { fish } = Astro.props;
---

<FishPage fish={fish} />
