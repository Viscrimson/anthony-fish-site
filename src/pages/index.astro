---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths.js";

const profileFields = [
  ["Name", "TODO: Anthony preferred display name"],
  ["Degrees", "TODO: degrees or certifications to list"],
  ["Experience", "TODO: years and types of fishkeeping experience"],
  ["Societies / groups", "TODO: aquarium societies, clubs, or groups"],
  ["Fishkeeping focus", "TODO: fish species, habitats, or care topics"],
  ["Short biography", "TODO: short public biography for this site"],
  ["Contact info", "TODO: public contact method Anthony wants to share"],
];
---

<BaseLayout
  title="Anthony Fish Site"
  description="About Anthony and the hobby fish-care resources on Anthony Fish Site."
>
  <main class="page-wrap">
    <section class="hero home-hero">
      <div>
        <p class="eyebrow">Anthony Fish Site</p>
        <h1>About Anthony.</h1>
        <p class="lede">
          A hobby fish-care resource for practical care sheets, fishkeeping
          notes, and QR-linked care information. It is not an online store. If
          someone receives a fish from Anthony, the QR code on the bag can open
          that fish's care sheet.
        </p>
      </div>
    </section>

    <section class="content-section" aria-labelledby="who-i-am">
      <div>
        <p class="eyebrow">Profile</p>
        <h2 id="who-i-am">Public profile</h2>
      </div>
      <dl class="profile-list">
        {
          profileFields.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="link-grid" aria-label="Site sections">
      <a class="feature-link" href={withBase("fish/")}>
        <p class="eyebrow">Care Sheets</p>
        <h2>Fish Care Sheets</h2>
        <p>
          Species and variety care pages that can be shared directly. QR codes
          on fish bags can point to the matching care sheet.
        </p>
      </a>
      <a class="feature-link" href={withBase("notes/")}>
        <p class="eyebrow">Articles</p>
        <h2>Fishkeeping Notes</h2>
        <p>
          Short hobby articles, setup notes, and care observations that do not
          need to be tied to one fish care sheet.
        </p>
      </a>
    </section>
  </main>
</BaseLayout>
