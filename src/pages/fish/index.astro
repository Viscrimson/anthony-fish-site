---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { trimText } from "../../lib/content-display.js";
import { buildFishPages } from "../../lib/content-pages.js";
import { fishImage } from "../../lib/paths.js";

const fishPages = buildFishPages(await getCollection("fish"));
const fishCards = fishPages.map((fish) => {
  const chips = [];
  const seen = new Set();
  const addChip = (value) => {
    const text = trimText(value);

    if (!text || seen.has(text)) {
      return;
    }

    seen.add(text);
    chips.push(text);
  };

  addChip(fish.difficulty);
  addChip(fish.temperatureRange);
  addChip(fish.tankSize);
  addChip(fish.temperament);

  return {
    ...fish,
    chips,
  };
});
---

<BaseLayout
  title="Fish Care Sheets"
  description="Fish care sheets from Anthony Fish Site."
>
  <main class="page-wrap">
    <section class="hero">
      <div>
        <p class="eyebrow">Care Sheets</p>
        <h1>Fish Care Sheets.</h1>
        <p class="lede">
          Practical fish care pages for species, varieties, and individual care
          notes. These pages are meant to be easy to share from QR codes on fish
          bags.
        </p>
      </div>
    </section>

    <section class="fish-grid" aria-label="Fish care sheets">
      {
        fishCards.map((fish) => (
          <a class="fish-card" href={fish.url}>
            <img src={fishImage(fish.mainImage)} alt={`${fish.commonName} care sheet image`} />
            <div class="fish-card-copy">
              <p class="eyebrow">Care sheet</p>
              <h2>{fish.commonName}</h2>
              <p><em>{fish.scientificName}</em></p>
              {trimText(fish.summary) ? <p>{fish.summary}</p> : null}
              {
                fish.chips.length ? (
                  <ul class="fish-chip-list" aria-label={`${fish.commonName} quick care facts`}>
                    {fish.chips.map((chip) => <li class="fish-chip">{chip}</li>)}
                  </ul>
                ) : null
              }
            </div>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
