---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { trimText } from "../../lib/content-display.js";
import { buildNotePages } from "../../lib/content-pages.js";
import { withBase } from "../../lib/paths.js";

const notePages = buildNotePages(await getCollection("notes"));

const formatDate = (date) =>
  new Intl.DateTimeFormat("en-US", {
    dateStyle: "medium",
    timeZone: "UTC",
  }).format(date);
---

<BaseLayout
  title="Fishkeeping Notes"
  description="Fishkeeping notes and short articles from Anthony Fish Site."
>
  <main class="page-wrap">
    <section class="hero">
      <div>
        <p class="eyebrow">Articles</p>
        <h1>Fishkeeping Notes.</h1>
        <p class="lede">
          Short notes about care routines, aquarium setup, and how to use this
          hobby resource.
        </p>
      </div>
    </section>

    <section class="article-list" aria-label="Fishkeeping notes">
      {
        notePages.map((note) => (
          <a class="article-card" href={note.url}>
            <p class="eyebrow">{formatDate(note.date)}</p>
            <h2>{note.title}</h2>
            {trimText(note.summary) ? <p>{note.summary}</p> : null}
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
