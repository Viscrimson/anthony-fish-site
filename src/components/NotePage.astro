---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentPager from "./ContentPager.astro";
import { compactSources, compactStrings, hasText, trimText } from "../lib/content-display.js";
import { noteImage, withBase } from "../lib/paths.js";

const {
  note,
  Content,
  previousNote = null,
  nextNote = null,
  relatedFish = [],
  relatedNotes = [],
} = Astro.props;
const summary = trimText(note.data.summary);
const category = trimText(note.data.category);
const quickAnswer = trimText(note.data.quickAnswer);
const practicalSteps = compactStrings(
  note.data.practicalSteps ?? note.data.pictorialSteps,
);
const visualNote = trimText(
  note.data.visualNote ?? note.data.illustrationsDataTechnique,
);
const galleryImages = compactStrings(note.data.galleryImages);
const published = new Intl.DateTimeFormat("en-US", {
  dateStyle: "medium",
  timeZone: "UTC",
}).format(note.data.date);
const hasUpdatedDate =
  note.data.lastUpdated instanceof Date &&
  note.data.lastUpdated.getTime() !== note.data.date.getTime();
const updated = hasUpdatedDate
  ? new Intl.DateTimeFormat("en-US", {
      dateStyle: "medium",
      timeZone: "UTC",
    }).format(note.data.lastUpdated)
  : "";
const hasReviewedDate =
  note.data.lastReviewed instanceof Date &&
  note.data.lastReviewed.getTime() !==
    (hasUpdatedDate ? note.data.lastUpdated.getTime() : note.data.date.getTime());
const reviewed = hasReviewedDate
  ? new Intl.DateTimeFormat("en-US", {
      dateStyle: "medium",
      timeZone: "UTC",
    }).format(note.data.lastReviewed)
  : "";

const metaItems = [
  ...(hasText(category) ? [{ label: "Category", value: category }] : []),
  {
    label: "Published",
    value: published,
  },
  ...(hasUpdatedDate ? [{ label: "Updated", value: updated }] : []),
  ...(hasReviewedDate ? [{ label: "Reviewed", value: reviewed }] : []),
];
const sourceEntries = compactSources(note.data.sources);
---

<BaseLayout title={note.data.title} description={summary || note.data.title}>
  <main class="page-wrap article-page note-page">
    <p class="crumb"><a href={withBase("notes/")}>All resources</a></p>
    <article class="article-shell">
      <p class="eyebrow">Resource</p>
      <h1>{note.data.title}</h1>
      {summary ? <p class="lede">{summary}</p> : null}

      <dl class="note-meta">
        {metaItems.map(({ label, value }) => (
          <div>
            <dt>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))}
      </dl>

      {
        quickAnswer ? (
          <section class="note-section note-callout" aria-labelledby="quick-answer">
            <h2 id="quick-answer">Quick answer</h2>
            <p>{quickAnswer}</p>
          </section>
        ) : null
      }

      {
        practicalSteps.length ? (
          <section class="note-section">
            <h2>Practical steps</h2>
            <ol class="step-list">
              {practicalSteps.map((step) => <li>{step}</li>)}
            </ol>
          </section>
        ) : null
      }

      {
        hasText(visualNote) ? (
          <section class="note-section">
            <h2>Visual note</h2>
            <p>{visualNote}</p>
          </section>
        ) : null
      }

      {
        galleryImages.length ? (
          <section class="note-section">
            <h2>Photos</h2>
            <div class="note-gallery" aria-label={`${note.data.title} photos`}>
              {galleryImages.map((image, index) => (
                <img
                  src={noteImage(image)}
                  alt={`${note.data.title} image ${index + 1}`}
                  loading="lazy"
                />
              ))}
            </div>
          </section>
        ) : null
      }

      <div class="note-body">
        <Content />
      </div>

      {
        sourceEntries.length || hasReviewedDate ? (
          <section class="note-section" aria-labelledby="sources-and-review">
            <h2 id="sources-and-review">Sources and review</h2>
            {sourceEntries.length ? (
              <ul class="source-list">
                {sourceEntries.map((source) => (
                  <li class="source-item">
                    {source.href ? (
                      <a
                        class="source-link"
                        href={source.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="source-link-label">{source.label}</span>
                        {source.detail ? (
                          <span class="source-link-detail">{source.detail}</span>
                        ) : null}
                      </a>
                    ) : (
                      <div class="source-link">
                        <span class="source-link-label">{source.label}</span>
                        {source.detail ? (
                          <span class="source-link-detail">{source.detail}</span>
                        ) : null}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            ) : null}
            {hasReviewedDate ? <p>Last reviewed: {reviewed}</p> : null}
          </section>
        ) : null
      }

      {
        relatedFish.length ? (
          <section class="content-section" aria-labelledby="related-care-sheets">
            <div>
              <p class="eyebrow">Related content</p>
              <h2 id="related-care-sheets">Related care sheets</h2>
            </div>
            <div class="article-list related-content-list">
              {relatedFish.map((fish) => (
                <a class="article-card related-card" href={fish.url}>
                  <p class="eyebrow">Care sheet</p>
                  <h2>{fish.commonName}</h2>
                  {hasText(fish.scientificName) ? (
                    <p class="scientific-name">
                      <em>{fish.scientificName}</em>
                    </p>
                  ) : null}
                  {hasText(fish.summary) ? <p>{fish.summary}</p> : null}
                </a>
              ))}
            </div>
          </section>
        ) : null
      }

      {
        relatedNotes.length ? (
          <section class="content-section" aria-labelledby="related-notes">
            <div>
              <p class="eyebrow">Related content</p>
              <h2 id="related-notes">Related resources</h2>
            </div>
            <div class="article-list related-content-list">
              {relatedNotes.map((relatedNote) => (
                <a class="article-card related-card" href={relatedNote.url}>
                  {hasText(relatedNote.category) ? (
                    <p class="eyebrow">{relatedNote.category}</p>
                  ) : null}
                  <h2>{relatedNote.title}</h2>
                  {hasText(relatedNote.summary) ? <p>{relatedNote.summary}</p> : null}
                </a>
              ))}
            </div>
          </section>
        ) : null
      }

      <ContentPager
        ariaLabel="Resource navigation"
        previous={previousNote && { label: previousNote.label, url: previousNote.url }}
        next={nextNote && { label: nextNote.label, url: nextNote.url }}
        previousLabel="Previous resource"
        nextLabel="Next resource"
      />
    </article>
  </main>
</BaseLayout>
