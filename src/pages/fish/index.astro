---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  deriveTemperamentStyle,
  deriveTankBand,
  displayDifficulty,
  hasText,
  trimText,
} from "../../lib/content-display.js";
import { buildFishPages } from "../../lib/content-pages.js";
import { fishImage } from "../../lib/paths.js";

const collator = new Intl.Collator("en", {
  sensitivity: "base",
});

const fishPages = buildFishPages(await getCollection("fish"));
const fishCards = fishPages.map((fish) => {
  const tankBand = deriveTankBand(fish.tankSize);
  const temperamentStyle = deriveTemperamentStyle(fish.temperament);
  const difficultyLabel = displayDifficulty(fish.difficulty).toLowerCase();
  const difficultyRank = new Map([
    ["beginner", 0],
    ["intermediate", 2],
    ["advanced", 3],
  ]).get(difficultyLabel) ?? Number.POSITIVE_INFINITY;

  return {
    ...fish,
    searchIndex: fish.searchIndex,
    nameSort: trimText(fish.commonName),
    difficultyFilter: difficultyLabel,
    difficultySort: difficultyRank,
    tankFilter: tankBand?.value ?? "",
    tankFilterLabel: tankBand?.label ?? "",
    tankFilterSort: tankBand?.sort ?? Number.POSITIVE_INFINITY,
    temperamentFilter: temperamentStyle?.value ?? "",
    temperamentFilterLabel: temperamentStyle?.label ?? "",
  };
});

const dedupeOptions = (options) => {
  const seen = new Set();

  return options.filter((option) => {
    if (!option.value || seen.has(option.value)) {
      return false;
    }

    seen.add(option.value);
    return true;
  });
};

const difficultyOptions = dedupeOptions(
  [
    ...fishCards
      .map((fish) => {
        const label = displayDifficulty(fish.difficulty);

        return label ? { value: label.toLowerCase(), label } : null;
      })
      .filter(Boolean),
    { value: "advanced", label: "Advanced" },
  ],
).sort((left, right) => {
  const difficultyOrder = new Map([
    ["beginner", 0],
    ["intermediate", 2],
    ["advanced", 3],
  ]);
  const leftRank = difficultyOrder.get(left.value) ?? Number.POSITIVE_INFINITY;
  const rightRank = difficultyOrder.get(right.value) ?? Number.POSITIVE_INFINITY;

  return leftRank - rightRank || collator.compare(left.label, right.label);
});

const tankOptions = dedupeOptions(
  [
    ...fishCards
      .map((fish) =>
        fish.tankFilter
          ? {
              value: fish.tankFilter,
              label: fish.tankFilterLabel,
              sort: fish.tankFilterSort,
            }
          : null,
      )
      .filter(Boolean),
    { value: "75", label: "75+ gallons", sort: 75 },
  ],
).sort((left, right) => left.sort - right.sort || collator.compare(left.label, right.label));

const temperamentOptions = dedupeOptions(
  fishCards
    .map((fish) =>
      fish.temperamentFilter
        ? {
            value: fish.temperamentFilter,
            label: fish.temperamentFilterLabel,
          }
        : null,
    )
    .filter(Boolean),
).sort((left, right) => collator.compare(left.label, right.label));

const totalFishCount = fishCards.length;
const totalFishLabel = totalFishCount === 1 ? "care sheet" : "care sheets";
const sortOptions = [
  { value: "name-asc", label: "Name A-Z" },
  { value: "name-desc", label: "Name Z-A" },
  { value: "tank-asc", label: "Tank size, smallest first" },
  { value: "tank-desc", label: "Tank size, largest first" },
  { value: "difficulty-asc", label: "Difficulty, easiest first" },
  { value: "difficulty-desc", label: "Difficulty, hardest first" },
];
---

<BaseLayout
  title="Care Sheet Library"
  description="Search the Care Sheet Library across the full care sheet text by name, tank size, temperature, difficulty, or temperament."
>
  <main class="page-wrap">
    <section class="hero">
      <div>
        <h1>Care Sheet Library</h1>
        <p class="lede">
          Every species has its own needs. Search by name or compare tank size, temperature,
          temperament, and care level to find fish that fit your aquarium—not just fish that catch
          your eye.
        </p>
      </div>
    </section>

    <section class="fish-tools" aria-label="Care Sheet Library search controls">
      <details class="library-search">
        <summary class="library-search-summary">
          <span class="library-search-summary-copy">
            <span class="library-search-kicker">Search and filter</span>
            <span class="library-search-heading">Find the right care sheet</span>
            <span class="library-search-lede">
              Search by name or compare the tank size, temperament, and care level your aquarium needs.
            </span>
          </span>
          <span class="library-search-toggle" aria-hidden="true"></span>
        </summary>

        <div class="library-search-content">
          <form class="fish-tools-panel" data-fish-controls>
            <div class="fish-search-row">
              <label class="fish-search-field" for="fish-search">
                <span class="fish-control-label">Search care sheets</span>
                <input
                  id="fish-search"
                  name="search"
                  type="search"
                  autocomplete="off"
                  spellcheck="false"
                  placeholder="Search by name, scientific name, care facts, take-home notes, or other notes"
                  data-fish-search
                />
              </label>

              <label class="fish-search-field fish-sort-field" for="fish-sort">
                <span class="fish-control-label">Sort care sheets</span>
                <select id="fish-sort" name="sort" data-fish-sort>
                  {sortOptions.map((option) => (
                    <option value={option.value} selected={option.value === "name-asc"}>
                      {option.label}
                    </option>
                  ))}
                </select>
              </label>

              <button type="reset" class="fish-reset">Clear search and filters</button>
            </div>

            <div class="fish-filter-grid">
              {
                difficultyOptions.length ? (
                  <fieldset class="fish-filter-group">
                    <legend>Difficulty</legend>
                    <div class="fish-filter-options">
                      {difficultyOptions.map((option) => (
                        <label class="fish-filter-option">
                          <input type="checkbox" name="difficulty" value={option.value} />
                          <span>{option.label}</span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                ) : null
              }

              {
                tankOptions.length ? (
                  <fieldset class="fish-filter-group">
                    <legend>Tank size</legend>
                    <div class="fish-filter-options">
                      {tankOptions.map((option) => (
                        <label class="fish-filter-option">
                          <input type="checkbox" name="tankSize" value={option.value} />
                          <span>{option.label}</span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                ) : null
              }

              {
                temperamentOptions.length ? (
                  <fieldset class="fish-filter-group">
                    <legend>Temperament</legend>
                    <div class="fish-filter-options">
                      {temperamentOptions.map((option) => (
                        <label class="fish-filter-option">
                          <input type="checkbox" name="temperament" value={option.value} />
                          <span>{option.label}</span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                ) : null
              }
            </div>
          </form>
        </div>
      </details>

      <p
        class="fish-results"
        data-fish-results
        role="status"
        aria-live="polite"
        aria-atomic="true"
      >
        Showing {totalFishCount} {totalFishLabel}
      </p>

      <p class="fish-empty-state" data-fish-empty hidden>
        No care sheets match those search terms or filters.
      </p>
    </section>

    <section class="fish-grid" aria-label="Care Sheet Library" data-fish-grid>
      {
        fishCards.map((fish) => (
          <a
            class="fish-card"
            href={fish.url}
            data-fish-card
            data-sort-name={fish.nameSort}
            data-sort-difficulty={fish.difficultySort}
            data-sort-tank={fish.tankFilterSort}
            data-search={fish.searchIndex}
            data-difficulty={fish.difficultyFilter}
            data-tank-size={fish.tankFilter}
            data-temperament={fish.temperamentFilter}
          >
            <img src={fishImage(fish.mainImage)} alt={`${fish.commonName} care sheet image`} />
            <div class="fish-card-copy">
              <h2>{fish.commonName}</h2>
              {hasText(fish.scientificName) ? (
                <p class="scientific-name">
                  <em>{fish.scientificName}</em>
                </p>
              ) : null}
            </div>
          </a>
          ))
      }
    </section>

    <nav class="list-pagination" data-fish-pagination aria-label="Care Sheet pagination">
      <button type="button" class="list-pagination-button" data-fish-page-prev>
        <span aria-hidden="true">&larr;</span>
        <span>Previous</span>
      </button>

      <p class="list-pagination-status" data-fish-page-status aria-live="polite" aria-atomic="true">
        Page 1 of 1
      </p>

      <button type="button" class="list-pagination-button" data-fish-page-next>
        <span>Next</span>
        <span aria-hidden="true">&rarr;</span>
      </button>
    </nav>
  </main>

  <script is:inline>
    const controls = document.querySelector("[data-fish-controls]");

    if (controls) {
      const cards = Array.from(document.querySelectorAll("[data-fish-card]"));
      const grid = document.querySelector("[data-fish-grid]");
      const searchInput = controls.querySelector("[data-fish-search]");
      const sortInput = controls.querySelector("[data-fish-sort]");
      const status = document.querySelector("[data-fish-results]");
      const emptyState = document.querySelector("[data-fish-empty]");
      const pagination = document.querySelector("[data-fish-pagination]");
      const pageStatus = document.querySelector("[data-fish-page-status]");
      const prevButton = document.querySelector("[data-fish-page-prev]");
      const nextButton = document.querySelector("[data-fish-page-next]");

      if (
        grid &&
        searchInput &&
        sortInput &&
        status &&
        emptyState &&
        pagination &&
        pageStatus &&
        prevButton &&
        nextButton
      ) {
        const filterInputs = Array.from(
          controls.querySelectorAll('input[type="checkbox"]'),
        );
        const normalizeText = (value) =>
          String(value ?? "")
            .toLowerCase()
            .replace(/\s+/g, " ")
            .trim();
        const getPageSize = () => {
          if (window.innerWidth <= 760) {
            return 4;
          }

          if (window.innerWidth <= 1024) {
            return 6;
          }

          return 8;
        };
        let pageSize = getPageSize();
        let currentPage = 1;

        const getSelectedValues = (name) =>
          new Set(
            Array.from(controls.querySelectorAll(`input[name="${name}"]:checked`)).map(
              (input) => input.value,
            ),
          );

        const compareText = (left, right, direction = 1) =>
          direction * left.localeCompare(right, "en", { sensitivity: "base" });

        const compareNumeric = (left, right, direction = 1) => {
          const leftMissing = !Number.isFinite(left);
          const rightMissing = !Number.isFinite(right);

          if (leftMissing && rightMissing) {
            return 0;
          }

          if (leftMissing) {
            return 1;
          }

          if (rightMissing) {
            return -1;
          }

          return direction * (left - right);
        };

        const compareCards = (left, right) => {
          switch (sortInput.value) {
            case "name-desc":
              return compareText(right.dataset.sortName || "", left.dataset.sortName || "");
            case "tank-asc":
              return compareNumeric(
                Number(left.dataset.sortTank || "NaN"),
                Number(right.dataset.sortTank || "NaN"),
              );
            case "tank-desc":
              return compareNumeric(
                Number(right.dataset.sortTank || "NaN"),
                Number(left.dataset.sortTank || "NaN"),
              );
            case "difficulty-asc":
              return compareNumeric(
                Number(left.dataset.sortDifficulty || "NaN"),
                Number(right.dataset.sortDifficulty || "NaN"),
              );
            case "difficulty-desc":
              return compareNumeric(
                Number(right.dataset.sortDifficulty || "NaN"),
                Number(left.dataset.sortDifficulty || "NaN"),
              );
            case "name-asc":
            default:
              return compareText(left.dataset.sortName || "", right.dataset.sortName || "");
          }
        };

        const updateResults = () => {
          const query = normalizeText(searchInput.value);
          const difficultyValues = getSelectedValues("difficulty");
          const tankValues = getSelectedValues("tankSize");
          const temperamentValues = getSelectedValues("temperament");
          const tankThresholds = Array.from(tankValues)
            .map((value) => Number(value))
            .filter((value) => Number.isFinite(value));
          let visibleCount = 0;
          const orderedCards = cards.slice().sort(compareCards);
          const matchedCards = [];

          for (const card of orderedCards) {
            const searchText = normalizeText(card.dataset.search || card.textContent);
            const matchesSearch = !query || searchText.includes(query);
            const matchesDifficulty =
              !difficultyValues.size || difficultyValues.has(card.dataset.difficulty || "");
            const matchesTank =
              !tankThresholds.length ||
              tankThresholds.some(
                (threshold) => Number(card.dataset.tankSize || "0") >= threshold,
              );
            const matchesTemperament =
              !temperamentValues.size || temperamentValues.has(card.dataset.temperament || "");
            const isVisible =
              matchesSearch && matchesDifficulty && matchesTank && matchesTemperament;

            card.hidden = true;

            if (isVisible) {
              visibleCount += 1;
              matchedCards.push(card);
            }
          }

          const totalPages = visibleCount > 0 ? Math.ceil(visibleCount / pageSize) : 0;

          currentPage = totalPages ? Math.min(currentPage, totalPages) : 1;

          const startIndex = (currentPage - 1) * pageSize;
          const pageCards = matchedCards.slice(startIndex, startIndex + pageSize);

          for (const card of pageCards) {
            card.hidden = false;
          }

          grid.append(...orderedCards);

          const visibleLabel = visibleCount === 1 ? "care sheet" : "care sheets";
          const totalLabel = cards.length === 1 ? "care sheet" : "care sheets";

          status.textContent =
            visibleCount === cards.length
              ? `Showing ${visibleCount} ${visibleLabel}`
              : `Showing ${visibleCount} of ${cards.length} ${totalLabel}`;

          emptyState.hidden = visibleCount !== 0;
          pagination.hidden = visibleCount === 0;
          pageStatus.textContent = totalPages > 0 ? `Page ${currentPage} of ${totalPages}` : "";
          prevButton.disabled = currentPage <= 1 || totalPages <= 1;
          nextButton.disabled = currentPage >= totalPages || totalPages <= 1;
        };

        const syncPageSize = () => {
          const nextPageSize = getPageSize();

          if (nextPageSize !== pageSize) {
            pageSize = nextPageSize;
            currentPage = 1;
            updateResults();
          }
        };

        const resetToFirstPage = () => {
          currentPage = 1;
          updateResults();
        };

        searchInput.addEventListener("input", resetToFirstPage);
        searchInput.addEventListener("change", resetToFirstPage);
        searchInput.addEventListener("search", resetToFirstPage);
        sortInput.addEventListener("change", resetToFirstPage);
        filterInputs.forEach((input) => input.addEventListener("change", resetToFirstPage));
        prevButton.addEventListener("click", () => {
          currentPage = Math.max(1, currentPage - 1);
          updateResults();
        });
        nextButton.addEventListener("click", () => {
          currentPage += 1;
          updateResults();
        });
        controls.addEventListener("reset", () => {
          window.requestAnimationFrame(() => {
            currentPage = 1;
            updateResults();
          });
        });
        controls.addEventListener("submit", (event) => {
          event.preventDefault();
        });
        window.addEventListener("resize", syncPageSize);

        updateResults();
      }
    }
  </script>
</BaseLayout>
