---
import { getCollection } from "astro:content";
import { withBase } from "../lib/paths.js";
import { trimText } from "../lib/content-display.js";
import "../styles/site.css";

const siteName = "Anthony Fish Care";
const siteEntry = (await getCollection("site"))[0] ?? null;
const siteContent = siteEntry?.data ?? {};

const {
  title = siteName,
  description = "Fish care sheets and resources from Anthony Fish Care.",
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const brandName = trimText(siteContent.siteName) || siteName;
const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const homePath = withBase();
const fishPath = withBase("fish/");
const notesPath = withBase("notes/");
const isHomePath = currentPath === homePath;
const isFishPath = currentPath === fishPath || currentPath.startsWith(fishPath);
const isNotesPath = currentPath === notesPath || currentPath.startsWith(notesPath);
const navItems = [
  {
    href: withBase("fish/"),
    label: "Care Sheet Library",
    current: isFishPath ? "page" : undefined,
  },
  {
    href: withBase("notes/"),
    label: "Resources",
    current: isNotesPath ? "page" : undefined,
  },
  {
    href: withBase("#about"),
    label: "About",
    current: isHomePath ? "location" : undefined,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href={withBase("favicon.svg")} />
  </head>
  <body>
    <header class="site-header">
      <a class="site-brand" href={withBase()}>
        <span class="site-brand-mark" aria-hidden="true">AF</span>
        <span class="site-brand-name">{brandName}</span>
      </a>
      <nav class="site-nav site-nav-desktop" aria-label="Main navigation">
        {navItems.map((item) => (
          <a href={item.href} aria-current={item.current}>
            {item.label}
          </a>
        ))}
      </nav>
      <details class="site-menu">
        <summary class="site-menu-toggle">
          <span class="site-menu-toggle-label">Menu</span>
          <span class="site-menu-toggle-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </summary>
        <nav class="site-nav site-nav-mobile" aria-label="Main navigation">
          {navItems.map((item) => (
            <a href={item.href} aria-current={item.current}>
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </header>
    <slot />
    <footer class="site-footer">
      <p>
        © {currentYear} {brandName} · Designed by Juxtaposition Sound &amp; Vision
      </p>
    </footer>
  </body>
</html>
