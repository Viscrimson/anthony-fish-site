---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths.js";
import { hasText, trimText } from "../lib/content-display.js";

const fallbackSite = {
  siteName: "Anthony Fish Care",
  tagline: "Freshwater care sheets and resources for fish Anthony sends home.",
  homepageEyebrow: "Anthony Fish Care",
  homepageTitle: "Start here for care instructions",
  homepageIntro:
    "If you scanned a fish bag, start with that fish's care sheet. Use the Care Sheet Library for quick species details and Resources for setup, acclimation, and water-quality help.",
  careSheetsIntro:
    "Care sheets with tank size, temperature, food, and warning notes kept easy to scan.",
  notesIntro:
    "Short resources for setup, acclimation, water quality, feeding, and other practical questions.",
  aboutHeading: "About this site",
  aboutSummary:
    "Anthony Fish Care keeps the essential fish information in one place so it is easy to read on a phone.",
  experienceText:
    "Open the matching care sheet first, then use Resources when you want more context.",
  focusText:
    "Freshwater fish, tank basics, acclimation, water testing, feeding, and care notes.",
  contactHeading: "Contact",
  contactText:
    "Contact details can be added later if Anthony wants them public.",
  showContact: false,
  showCredentials: false,
  showGroups: false,
};

const siteEntry = (await getCollection("site"))[0] ?? null;
const site = siteEntry?.data ?? fallbackSite;
const siteName = trimText(site.siteName) || fallbackSite.siteName;
const tagline = trimText(site.tagline) || fallbackSite.tagline;
const homepageEyebrow =
  trimText(site.homepageEyebrow) || fallbackSite.homepageEyebrow;
const homepageTitle = trimText(site.homepageTitle) || fallbackSite.homepageTitle;
const homepageIntro = trimText(site.homepageIntro) || fallbackSite.homepageIntro;
const careSheetsIntro =
  trimText(site.careSheetsIntro) || fallbackSite.careSheetsIntro;
const notesIntro = trimText(site.notesIntro) || fallbackSite.notesIntro;
const aboutHeading = trimText(site.aboutHeading) || fallbackSite.aboutHeading;
const aboutSummary = trimText(site.aboutSummary) || fallbackSite.aboutSummary;
const experienceText = trimText(site.experienceText);
const focusText = trimText(site.focusText);
const credentialsText =
  site.showCredentials === true ? trimText(site.credentialsText) : "";
const groupsText = site.showGroups === true ? trimText(site.groupsText) : "";
const contactVisible =
  siteEntry ? site.showContact === true : fallbackSite.showContact === true;
const contactHeading =
  trimText(site.contactHeading) || fallbackSite.contactHeading;
const contactText = trimText(site.contactText) || fallbackSite.contactText;

const aboutFields = [
  ["How to use it", experienceText],
  ["What it covers", focusText],
  ["Credentials", credentialsText],
  ["Groups", groupsText],
].filter(([, value]) => hasText(value));
const aboutVisible = hasText(aboutSummary) || aboutFields.length > 0;
---

<BaseLayout
  title={siteName}
  description={tagline}
>
  <main class="page-wrap">
    <section class="hero home-hero">
      <div>
        <p class="eyebrow">{homepageEyebrow}</p>
        <h1>{homepageTitle}</h1>
        <p class="lede">{homepageIntro}</p>
      </div>

      <p class="home-purpose-intro">Scan the bag, browse the library, or look at other resources.</p>
      <div class="home-purpose-grid" aria-label="What visitors can do here">
        <article class="home-purpose-card">
          <p class="home-purpose-label">Scan a bag</p>
          <p>The QR on the bag opens the matching care sheet with the important facts first.</p>
        </article>
        <article class="home-purpose-card">
          <p class="home-purpose-label">Care Sheet Library</p>
          <p>Browse a fish by name, scientific name, tank size, difficulty, or temperament.</p>
        </article>
        <article class="home-purpose-card">
          <p class="home-purpose-label">Resources</p>
          <p>Open short resources for setup, acclimation, water quality, feeding, and follow-up questions.</p>
        </article>
      </div>
    </section>

    <section class="link-grid" aria-label="Site sections">
      <a class="feature-link" href={withBase("fish/")}>
        <p class="eyebrow">Care Sheet Library</p>
        <h2>Care Sheet Library</h2>
        <p>{careSheetsIntro}</p>
        <span class="feature-link-action">Open the library →</span>
      </a>
      <a class="feature-link" href={withBase("notes/")}>
        <p class="eyebrow">Resources</p>
        <h2>Resources</h2>
        <p>{notesIntro}</p>
        <span class="feature-link-action">Open resources →</span>
      </a>
    </section>

    {
      aboutVisible ? (
        <section class="content-section home-about-section" id="about" aria-labelledby="about-anthony">
          <div>
            <p class="eyebrow">About the site</p>
            <h2 id="about-anthony">{aboutHeading}</h2>
          </div>
          <div>
            {hasText(aboutSummary) ? <p class="lede">{aboutSummary}</p> : null}
            <dl class="profile-list">
              {aboutFields.map(([label, value]) => (
                <div>
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </section>
      ) : null
    }

    {
      contactVisible && hasText(contactText) ? (
        <section class="content-section" id="contact" aria-labelledby="contact-anthony">
          <div>
            <p class="eyebrow">Contact</p>
            <h2 id="contact-anthony">{contactHeading}</h2>
          </div>
          <div class="site-helper">
            <p>{contactText}</p>
          </div>
        </section>
      ) : null
    }
  </main>
</BaseLayout>
