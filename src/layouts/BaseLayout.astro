---
import { withBase } from "../lib/paths.js";
import "../styles/site.css";

const {
  title = "Anthony Fish Site",
  description = "A simple static fish catalog.",
} = Astro.props;

const pageTitle =
  title === "Anthony Fish Site" ? title : `${title} | Anthony Fish Site`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href={withBase("favicon.svg")} />
  </head>
  <body>
    <header class="site-header">
      <a class="site-brand" href={withBase()}>Anthony Fish Site</a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href={withBase("fish/")}>Fish Care Sheets</a>
        <a href={withBase("notes/")}>Fishkeeping Notes</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <div>
        <p class="footer-title">Anthony Fish Site</p>
        <p>
          A hobby fish-care resource for sharing care sheets, fishkeeping notes,
          and QR-linked care information. This is not a store.
        </p>
      </div>
      <div>
        <p class="footer-title">Contact</p>
        <p>TODO: Anthony contact info.</p>
      </div>
    </footer>
  </body>
</html>
