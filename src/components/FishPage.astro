---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentPager from "./ContentPager.astro";
import {
  compactStrings,
  displayDifficulty,
  hasText,
  trimText,
} from "../lib/content-display.js";
import { fishImage, withBase } from "../lib/paths.js";

const { fish, previousFish = null, nextFish = null, relatedNotes = [] } = Astro.props;
const quickSummary = trimText(fish.qrSummary);
const placeholderImage = "fish-placeholder.svg";
const hasRenderableImage = (value) => {
  const image = trimText(value);

  return image && image !== placeholderImage;
};
const booleanFact = (label, value) =>
  typeof value === "boolean" ? [label, value ? "Yes" : "No"] : null;
const quickCareFacts = [
  ["Tank size", fish.tankSize],
  ["Adult size", fish.adultSize],
  ["Temperature", fish.temperatureRange],
  ["Origin", fish.origin],
  ["Food", fish.foodRecommendation],
  ["Difficulty", displayDifficulty(fish.difficulty)],
  ["Temperament", fish.temperament],
  booleanFact("Plant safe", fish.plantSafe),
  booleanFact("Invertebrate safe", fish.invertebrateSafe),
]
  .filter((entry) => Array.isArray(entry) && hasText(entry[1]));

const appearanceCards = [
  {
    label: "Juvenile",
    image: fish.juvenileImage,
    notes: fish.juvenileAppearance,
  },
  {
    label: "Adult male",
    image: fish.maleImage,
    notes: fish.adultMaleAppearance,
  },
  {
    label: "Adult female",
    image: fish.femaleImage,
    notes: fish.adultFemaleAppearance,
  },
].filter(({ image, notes }) => hasRenderableImage(image) || hasText(notes));

const galleryImages = compactStrings(fish.galleryImages).filter(hasRenderableImage);
const quickWarnings = compactStrings(fish.quickWarnings);
const husbandryNotes = trimText(fish.husbandryNotes);
const pageUrl = fish.url;
---

<BaseLayout title={fish.commonName} description={fish.commonName}>
  <main class="page-wrap fish-detail">
    <p class="crumb"><a href={withBase("fish/")}>Care Sheet Library</a></p>
    <section class="fish-profile fish-profile-expanded">
      <div class="fish-photo-panel">
        <img src={fishImage(fish.mainImage)} alt={`${fish.commonName} main image`} />
      </div>

      <article class="fish-copy">
        <p class="eyebrow">Care sheet</p>
        <h1>{fish.commonName}</h1>
        <p class="scientific-name"><em>{fish.scientificName}</em></p>
      </article>
    </section>

    {
      quickCareFacts.length || quickSummary ? (
        <section class="quick-care-section" aria-labelledby="quick-care">
          <div class="quick-care-intro">
            <p class="eyebrow">Quick care</p>
            <h2 id="quick-care">Start here</h2>
            {quickSummary ? <p class="quick-care-summary">{quickSummary}</p> : null}
            <div class="quick-care-actions">
              <p class="qr-handoff-note">If this came from a QR code or bag label, check these facts first.</p>
              <button type="button" class="print-care-sheet" data-print-care-sheet>
                Print care sheet
              </button>
            </div>
            <p class="print-page-url">Online care sheet: {pageUrl}</p>
          </div>

          <div class="quick-care-layout">
            {
              quickWarnings.length ? (
                <aside class="quick-warning-panel" aria-labelledby="take-home-notes">
                  <p class="eyebrow">Take-home notes</p>
                  <h3 id="take-home-notes">Before you take it home</h3>
                  <ul class="quick-warning-list">
                    {quickWarnings.map((warning) => <li>{warning}</li>)}
                  </ul>
                </aside>
              ) : null
            }

            {
              quickCareFacts.length ? (
                <dl class="quick-care-grid" aria-label={`${fish.commonName} quick care facts`}>
                  {
                    quickCareFacts.map(([label, value]) => (
                      <div class="quick-care-item">
                        <dt>{label}</dt>
                        <dd>{value}</dd>
                      </div>
                    ))
                  }
                </dl>
              ) : null
            }
          </div>
        </section>
      ) : null
    }

    {
      appearanceCards.length ? (
        <section class="content-section fish-appearance-section" aria-labelledby="appearance">
          <div>
            <p class="eyebrow">Appearance</p>
            <h2 id="appearance">Juvenile, adult male, and adult female</h2>
          </div>
          <div class="appearance-grid">
            {
              appearanceCards.map(({ label, image, notes }) => (
                <article class="appearance-card">
                  {hasRenderableImage(image) ? (
                    <img
                      src={fishImage(image)}
                      alt={`${fish.commonName} ${label.toLowerCase()} image`}
                    />
                  ) : null}
                  <div>
                    <h3>{label}</h3>
                    {hasText(notes) ? <p>{notes}</p> : null}
                  </div>
                </article>
              ))
            }
          </div>
        </section>
      ) : null
    }

    {
      fish.showAdditionalPhotos !== false && galleryImages.length ? (
        <section class="content-section" aria-labelledby="fish-gallery">
          <div>
            <p class="eyebrow">Photos</p>
            <h2 id="fish-gallery">More photos</h2>
          </div>
          <div class="fish-gallery" aria-label={`${fish.commonName} photos`}>
            {galleryImages.map((image, index) => (
              <img
                src={fishImage(image)}
                alt={`${fish.commonName} photo ${index + 1}`}
                loading="lazy"
              />
            ))}
          </div>
        </section>
      ) : null
    }

    {
      husbandryNotes ? (
        <section class="fish-note-section" aria-labelledby="husbandry-notes">
          <div>
            <h2 id="husbandry-notes">Husbandry notes</h2>
          </div>
          <p>{husbandryNotes}</p>
        </section>
      ) : null
    }

    {
      relatedNotes.length ? (
        <section class="content-section related-notes-section" aria-labelledby="related-notes">
          <div>
            <h2 id="related-notes">Other recommendations</h2>
          </div>
          <div class="article-list related-content-list">
            {relatedNotes.map((note) => (
              <a class="article-card related-card" href={note.url}>
                {hasText(note.category) ? <p class="eyebrow">{note.category}</p> : null}
                <h2>{note.title}</h2>
                {hasText(note.summary) ? <p>{note.summary}</p> : null}
              </a>
            ))}
          </div>
        </section>
      ) : null
    }

    <ContentPager
      ariaLabel="Care sheet navigation"
      previous={previousFish && { label: previousFish.label, url: previousFish.url }}
      next={nextFish && { label: nextFish.label, url: nextFish.url }}
      previousLabel="Previous care sheet"
      nextLabel="Next care sheet"
    />
  </main>
  <script is:inline>
    const printButton = document.querySelector("[data-print-care-sheet]");

    if (printButton) {
      printButton.addEventListener("click", () => {
        window.print();
      });
    }
  </script>
</BaseLayout>
